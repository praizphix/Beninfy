# Database (Supabase / any Postgres)
# Use the Supabase Transaction Pooler URL for Vercel/runtime queries.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the direct Supabase database URL for Prisma migrations.
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"
# Optional migration-only override. Usually leave commented unless DIRECT_URL is not enough.
# PRISMA_MIGRATE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Supabase project values.
SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"
# Backend-only key for admin uploads to Supabase Storage. Never expose in browser code.
SUPABASE_SECRET_KEY="YOUR_SUPABASE_SECRET_KEY"
# Create this as a public Storage bucket in Supabase.
SUPABASE_STORAGE_BUCKET="beninfy-media"

# NextAuth / Auth.js
AUTH_SECRET=
# Vercel sets VERCEL_URL automatically; trustHost is enabled in auth.ts.
# AUTH_URL is optional; set if behind a custom domain and not auto-detected.
# AUTH_URL=https://beninfy.com

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Super admin email allowed during the one-time bootstrap / seed
ADMIN_EMAIL=info@beninfy.com
# Secret code required to create admins from /[locale]/admin-signup
ADMIN_SIGNUP_CODE=
# Keep disabled after the first super-admin has been created.
ALLOW_ADMIN_BOOTSTRAP=false

# Payments fail closed unless explicitly enabled and every required secret is set.
PAYMENTS_ENABLED=false
# PayOnUs Naira collection
# Use "test" for sandbox or "production" for live.
PAYONUS_ENVIRONMENT=test
PAYONUS_CLIENT_ID=
PAYONUS_CLIENT_SECRET=
PAYONUS_BUSINESS_ID=
# Merchant Dashboard -> Settings -> API -> Webhook Verification Key
PAYONUS_WEBHOOK_KEY=

# Legacy provider keys (unused by the current PayOnUs flow)
PAYAZA_PUBLIC_KEY=
PAYAZA_API_KEY=
PAYAZA_CONNECTION_MODE=Test
PAYAZA_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
