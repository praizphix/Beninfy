# Database (Neon / any Postgres). Use a pooled URL for Vercel runtime.
DATABASE_URL=

# NextAuth / Auth.js
AUTH_SECRET=
# Vercel sets VERCEL_URL automatically; trustHost is enabled in auth.ts.
# AUTH_URL is optional; set if behind a custom domain and not auto-detected.
# AUTH_URL=https://beninfy.com

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Super admin email (auto-promoted on registration / seed)
ADMIN_EMAIL=info@beninfy.com

# Paystack (optional — stub mode active when unset)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
